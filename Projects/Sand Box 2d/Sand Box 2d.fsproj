<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- .NET settings -->
        <TargetFrameworks>net10.0</TargetFrameworks>
        <TargetFrameworks Condition="'$(BuildMobileTargets)' == 'true'">net10.0-android;$(TargetFrameworks)</TargetFrameworks> <!-- For some reason, Android is required to come before desktop for Visual Studio to realize that mobile debug targets should be loaded! -->
        <TargetFrameworks Condition="'$(BuildMobileTargets)' == 'true' And $([System.OperatingSystem]::IsMacOS())">$(TargetFrameworks);net10.0-ios</TargetFrameworks> <!-- We don't require installing the macOS Vulkan SDK on Windows. Therefore, don't build for iOS if not on macOS. -->
        <OutputType>Exe</OutputType>
        <TargetPlatformIdentifier>$([MSBuild]::GetTargetPlatformIdentifier($(TargetFramework)))</TargetPlatformIdentifier> <!-- convenience property -->
        <ServerGarbageCollection Condition="'$(TargetPlatformIdentifier)' != 'ios'">True</ServerGarbageCollection>
        <TieredPGO>True</TieredPGO>
        <DisableFastUpToDateCheck>True</DisableFastUpToDateCheck>

        <!-- Project file local properties -->
        <BuildingMacOS>false</BuildingMacOS>
        <BuildingMacOS Condition="'$(TargetPlatformIdentifier)' == '' And (('$(RuntimeIdentifier)'=='' And $([System.OperatingSystem]::IsMacOS())) Or $(RuntimeIdentifier.StartsWith('osx')))">true</BuildingMacOS>
        <BlockCompression>BcCompression</BlockCompression>
        <BlockCompression Condition="'$(BuildingMacOS)'=='true' Or '$(TargetPlatformIdentifier)'=='ios' Or '$(TargetPlatformIdentifier)'=='android'">AstcCompression</BlockCompression>
        <NuPipeBuildTargets Condition="'$(NuPipeBuildTargets)' == ''">Restore;Build</NuPipeBuildTargets>
        <NuPipeBuildTargets Condition="'$(Restore)' == 'false'">Build</NuPipeBuildTargets>
        <MacOSVulkanSdk Condition="'$(MacOSVulkanSdk)' == ''"></MacOSVulkanSdk>

        <!-- F# compiler settings -->
        <WarnOn>FS1182</WarnOn>
        <NoWarn>FS0009;FS0052;FS1178;FS3391;FS3536;FS3560</NoWarn>
        <Tailcalls>False</Tailcalls>
        <WarningLevel>5</WarningLevel>
        <WarningsAsErrors>FS0026;FS0049;FS3239;$(WarningsAsErrors)</WarningsAsErrors>
 
        <!-- Mobile app settings -->
        <!-- - Mobile application name -->
        <ApplicationTitle>Sand Box 2d</ApplicationTitle>
        <!-- - Install name of mobile package
               Android: https://learn.microsoft.com/en-us/dotnet/android/building-apps/build-properties#applicationid
               iOS: https://learn.microsoft.com/en-us/dotnet/ios/building-apps/build-properties#applicationid -->
        <ApplicationId Condition="'$(ApplicationId)' == ''">nu.game.SandBox2d</ApplicationId>
        <!-- - Displayed version of mobile package -->
        <ApplicationDisplayVersion>1.0.0</ApplicationDisplayVersion>
        <!-- - Integer version of mobile package
               Android: https://learn.microsoft.com/en-us/dotnet/android/building-apps/build-properties#applicationversion
               iOS: https://learn.microsoft.com/en-us/dotnet/ios/building-apps/build-properties#applicationversion -->
        <ApplicationVersion>1</ApplicationVersion>
        <!-- - Minimum Android API level: set to at least 23 (Android 6.0) as required Xamarin.Google.Android.Play.Asset.Delivery -->
        <SupportedOSPlatformVersion Condition="'$(TargetPlatformIdentifier)'=='android'">23</SupportedOSPlatformVersion>
        <!--   For other minimum OS versions that .NET defaults to, refer to e.g. https://github.com/dotnet/core/blob/main/release-notes/10.0/supported-os.md for .NET 10 -->

        <!-- Required properties for mobile -->
        <!-- We use .NET MAUI SDK targets for <MauiIcon>, <MauiSplashScreen>, <MauiAsset>. -->
        <UseMaui Condition="'$(TargetPlatformIdentifier)'=='ios' Or '$(TargetPlatformIdentifier)'=='android'">true</UseMaui>
        <!-- Additionally, we need this flag to tell Visual Studio that switching the debug target between <TargetFrameworks> is enabled instead of only using the first one. -->
        <SingleProject Condition="'$(TargetPlatformIdentifier)'=='ios' Or '$(TargetPlatformIdentifier)'=='android'">true</SingleProject>
        <!-- However, we don't use MAUI UI libraries. -->
        <SkipValidateMauiImplicitPackageReferences Condition="'$(TargetPlatformIdentifier)'=='ios' Or '$(TargetPlatformIdentifier)'=='android'">true</SkipValidateMauiImplicitPackageReferences>
        <!-- iOS: Work around for using Xcode 26.3 with 26.2 support from .NET -->
        <ValidateXcodeVersion Condition="'$(TargetPlatformIdentifier)'=='ios'">false</ValidateXcodeVersion>
        <!-- Android: Debugging settings for asset packs https://learn.microsoft.com/en-us/dotnet/maui/android/asset-packs#test-asset-packs-locally -->
        <AndroidPackageFormat Condition="'$(TargetPlatformIdentifier)'=='android' And '$(Configuration)' == 'Debug'">aab</AndroidPackageFormat>
        <AndroidBundleToolExtraArgs Condition="'$(TargetPlatformIdentifier)'=='android' And '$(Configuration)' == 'Debug'">--local-testing</AndroidBundleToolExtraArgs>

        <NuGetPackageRoot Condition="'$(NuGetPackageRoot)' == ''">$(HOME)/.nuget/packages/</NuGetPackageRoot>
        <SandBox2dPpySdlVersion>2026.302.0</SandBox2dPpySdlVersion>
        <SandBox2dAssimpNetOriginalDir>$(MSBuildProjectDirectory)/../../Nu/Nu.Dependencies/AssimpNet/netstandard2.1</SandBox2dAssimpNetOriginalDir>
        <SandBox2dAssimpNetPatchedDir>$(MSBuildProjectDirectory)/$(BaseIntermediateOutputPath)ios-managed/$(TargetFramework)</SandBox2dAssimpNetPatchedDir>
        <SandBox2dAssimpNetReferencePath>$(SandBox2dAssimpNetOriginalDir)/AssimpNet.dll</SandBox2dAssimpNetReferencePath>
        <SandBox2dAssimpNetReferencePath Condition="'$(TargetPlatformIdentifier)'=='ios'">$(SandBox2dAssimpNetPatchedDir)/AssimpNet.dll</SandBox2dAssimpNetReferencePath>
    </PropertyGroup>

    <!-- Build Nu.Pipe only once even for multi-project builds -->
    <Target Name="BuildNuPipe" BeforeTargets="BeforeBuild" Condition="'$(SkipNuPipe)' != 'true'">
        <MSBuild Projects="../../Nu/Nu.Pipe/Nu.Pipe.fsproj" RemoveProperties="TargetFramework;RuntimeIdentifier;SelfContained" Targets="$(NuPipeBuildTargets)" />
    </Target>

    <Target Name="ResolveMacOSVulkanSdk" Condition="'$(MacOSVulkanSdk)' == '' And $([System.OperatingSystem]::IsMacOS()) And ('$(BuildingMacOS)'=='true' Or '$(TargetPlatformIdentifier)'=='ios')">
        <Exec Command="
            if [ -x ~/.bash_profile ]
            then source ~/.bash_profile
            fi
            if [ &quot;$VULKAN_SDK&quot; == &quot;&quot; ]
            then VULKAN_SDK=`ls -d ~/VulkanSDK/* | grep -E &quot;[^/]+/[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$&quot; | sort -V -r | head -n 1`
            fi
            echo &quot;$VULKAN_SDK&quot;" ConsoleToMsBuild="true">
            <Output TaskParameter="ConsoleOutput" PropertyName="MacOSVulkanSdk" />
        </Exec>
    </Target>

    <!-- Run Nu.Pipe -->
    <Target Name="NuPipe" BeforeTargets="ResizetizeCollectItems;AssignTargetPaths" DependsOnTargets="BuildNuPipe;ResolveMacOSVulkanSdk" Condition="'$(SkipNuPipe)' != 'true'">
        <Copy SourceFiles="App.config;AssetGraph.nuag;Overlayer.nuol" DestinationFolder="refinement-out/$(TargetFramework)" SkipUnchangedFiles="true" />
        <MSBuild Projects="../../Nu/Nu.Pipe/Nu.Pipe.fsproj" RemoveProperties="TargetFramework;RuntimeIdentifier;SelfContained" Properties="NoBuild=true;RunWorkingDirectory=$(MSBuildProjectDirectory);RunArguments=&quot;$(MSBuildProjectDirectory)/&quot; &quot;$(MSBuildProjectDirectory)/refinement-out/$(TargetFramework)/&quot; &quot;$(MSBuildProjectDirectory)/refinement/$(TargetFramework)/&quot; &quot;$(BlockCompression)&quot; &quot;False&quot;" Targets="Run" />
        <ItemGroup>
            <RawShaderAsset Include="Assets/**/*.vert;Assets/**/*.frag;Assets/**/*.geom;Assets/**/*.tesc;Assets/**/*.tese;Assets/**/*.comp" />
        </ItemGroup>
        <Copy SourceFiles="@(RawShaderAsset)" DestinationFiles="@(RawShaderAsset->'refinement-out/$(TargetFramework)/Assets/%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
        <Error Text="Missing macOS Vulkan SDK glslc at '$(MacOSVulkanSdk)/macOS/bin/glslc'." Condition="'$(TargetPlatformIdentifier)'=='ios' And !Exists('$(MacOSVulkanSdk)/macOS/bin/glslc')" />
        <Exec Condition="'$(TargetPlatformIdentifier)'=='ios'" Command="&quot;$(MacOSVulkanSdk)/macOS/bin/glslc&quot; &quot;%(RawShaderAsset.Identity)&quot; -o &quot;refinement-out/$(TargetFramework)/Assets/%(RawShaderAsset.RecursiveDir)%(RawShaderAsset.Filename)%(RawShaderAsset.Extension).spv&quot;" />
        <Exec Condition="'$(TargetPlatformIdentifier)'=='ios' And Exists('refinement-out/$(TargetFramework)')" Command="/bin/chmod -R u+w &quot;refinement-out/$(TargetFramework)&quot;" />
        <ItemGroup>
            <!-- Android packages assets as a fast-follow asset pack; iOS needs root-relative logical names in the app bundle. -->
            <MauiAsset Condition="'$(TargetPlatformIdentifier)'=='android'" Include="refinement-out/$(TargetFramework)/**/*.*" AssetPack="gameassets" DeliveryType="FastFollow" />
            <MauiAsset Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="refinement-out/$(TargetFramework)/**/*.*" LogicalName="%(RecursiveDir)%(Filename)%(Extension)" />
            <MauiAsset Condition="'$(TargetPlatformIdentifier)'==''" Include="refinement-out/$(TargetFramework)/**/*.*" />
        </ItemGroup>
        <!-- For desktop, just copy assets to output directory. -->
        <Copy Condition="'$(TargetPlatformIdentifier)' == ''" SourceFiles="@(MauiAsset)" DestinationFolder="$(MSBuildProjectDirectory)/bin/$(Configuration)/$(TargetFramework)/%(RecursiveDir)" SkipUnchangedFiles="true" OverwriteReadOnlyFiles="true" />
    </Target>

    <Target Name="RemoveStaleSandBox2dIosBundledAssets" BeforeTargets="_CopyResourcesToBundle" Condition="'$(TargetPlatformIdentifier)'=='ios'">
        <RemoveDir Directories="$(AppBundleDir)/Assets" Condition="Exists('$(AppBundleDir)/Assets')" />
        <RemoveDir Directories="$(AppBundleDir)/refinement-out" Condition="Exists('$(AppBundleDir)/refinement-out')" />
    </Target>
    <Target Name="CleanNuPipe" AfterTargets="Clean">
        <RemoveDir Directories="refinement" />
        <RemoveDir Directories="refinement-out" />
        <RemoveDir Directories="$(OutDir)/Assets" />
    </Target>

    <Target Name="OverridePublishDir" AfterTargets="AssignTargetPaths">
        <PropertyGroup>
            <PublishDir>$(OutputPath)</PublishDir>
        </PropertyGroup>
    </Target>

    <ItemGroup>
        <None Include="Assets\*" />
        <None Include="Assets\*\*" />
        <Compile Include="Assets.fs" />
        <Compile Include="Simulants.fs" />
        <Compile Include="ToyCharacter.fs" />
        <Compile Include="ToyBox.fs" />
        <Compile Include="RaceCourse.fs" />
        <Compile Include="FluidSim.fs" />
        <Compile Include="SandBox2d.fs" />
        <Compile Include="SandBox2dPlugin.fs" />
        <Compile Include="Program.fs" />

        <!-- iOS Information property list: https://learn.microsoft.com/en-us/dotnet/maui/macios/info-plist -->
        <None Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="Mobile/Info.plist" LogicalName="Info.plist" />
        <!-- iOS Privacy manifest: https://learn.microsoft.com/en-us/dotnet/maui/ios/privacy-manifest -->
        <BundleResource Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="Mobile/PrivacyInfo.xcprivacy" LogicalName="PrivacyInfo.xcprivacy" />
		
        <!-- To comply with Android resource naming rules, MauiIcon and MauiSplashScreen files names must be
            lowercase, start and end with a letter character, and contain only alphanumeric characters or underscores. -->
        <!-- MauiIcon (Composed icon): https://learn.microsoft.com/en-us/dotnet/maui/user-interface/images/app-icons#composed-icon -->
        <MauiIcon Condition="'$(TargetPlatformIdentifier)'=='ios' Or '$(TargetPlatformIdentifier)'=='android'" Include="Mobile/mobile_icon_bg.svg" ForegroundFile="Mobile/mobile_icon_fg.svg" />
        <!-- MauiSplashScreen (with background color): https://learn.microsoft.com/en-us/dotnet/maui/user-interface/images/splashscreen#add-tint-and-background-color -->
        <MauiSplashScreen Condition="'$(TargetPlatformIdentifier)'=='ios' Or '$(TargetPlatformIdentifier)'=='android'" Include="Mobile/mobile_icon_fg.svg" Color="#512BD4" /> <!-- For simplicity, icon_fg is both icon foreground and splash screen foreground. -->

        <None Include="AssetGraph.nuag" />
        <None Include="Overlayer.nuol" />
        <None Include="App.config" />
    </ItemGroup>

    <ItemGroup Condition="'$(TargetPlatformIdentifier)'=='android'">
		<PackageReference Include="Xamarin.Google.Android.Play.Asset.Delivery" Version="2.3.0.6" />

        <!-- We need this to AOT System.Drawing.Common on Mac when doing "dotnet publish" -->
        <PackageReference Include="System.Formats.Nrbf" Version="10.0.1" />

		<!-- Prevent linux binaries from being packaged on Android. Keep these updated with the version selected in the Nu project. -->
		<PackageReference Include="Silk.NET.Shaderc.Native" Version="2.21.0" ExcludeAssets="native" /> <!-- transitive dependency of Vortice.ShaderCompiler -->
		<PackageReference Include="Twizzle.ImGui-Bundle.NET" Version="1.91.5.2" ExcludeAssets="native" />

		<!-- Package Android shared libraries explicitly by ABI. -->
		<AndroidNativeLibrary Include="../../Nu/Nu.Dependencies/ShaderC/android/*/libshaderc_shared.so" />
		<AndroidNativeLibrary Include="../../Nu/Nu.Dependencies/ShaderC/android/*/libc++_shared.so" />
		<AndroidNativeLibrary Include="../../Nu/Nu.Dependencies/ImGui/android/*/libcimgui.so" />
		<AndroidNativeLibrary Include="../../Nu/Nu.Dependencies/AssimpNet/android/*/libassimp.so" />
		<!-- Download Vulkan validation layers here: https://github.com/KhronosGroup/Vulkan-ValidationLayers/releases -->
		<!--AndroidNativeLibrary Include="../../Nu/Nu.Dependencies/Vulkan-validation/**/*.so" Condition="'$(Configuration)' == 'Debug'" /-->
    </ItemGroup>

    <ItemGroup>
        <PackageReference Update="FSharp.Core" Version="10.0.103" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="$(NuGetPackageRoot)ppy.sdl3-cs/$(SandBox2dPpySdlVersion)/runtimes/ios/native/SDL3.xcframework" Kind="Framework" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="$(NuGetPackageRoot)ppy.sdl3_image-cs/$(SandBox2dPpySdlVersion)/runtimes/ios/native/SDL3_image.xcframework" Kind="Framework" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="$(NuGetPackageRoot)ppy.sdl3_ttf-cs/$(SandBox2dPpySdlVersion)/runtimes/ios/native/SDL3_ttf.xcframework" Kind="Framework" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="$(NuGetPackageRoot)ppy.sdl3_mixer-cs/$(SandBox2dPpySdlVersion)/runtimes/ios/native/SDL3_mixer.xcframework" Kind="Framework" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="..\..\Nu\Nu.Dependencies\AssimpNet\iOS\assimp.xcframework" Kind="Framework" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="..\..\Nu\Nu.Dependencies\BulletSharpPInvoke\iOS\bulletc.xcframework" Kind="Framework" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="..\..\Nu\Nu.Dependencies\JoltPhysics\iOS\joltc.xcframework" Kind="Framework" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="..\..\Nu\Nu.Dependencies\ImGui\iOS\cimgui.xcframework" Kind="Framework" />
        <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="..\..\Nu\Nu.Dependencies\Vortice.VulkanMemoryAllocator\iOS\vma.xcframework" Kind="Framework" />
        <Reference Include="AssimpNet">
            <HintPath>$(SandBox2dAssimpNetReferencePath)</HintPath>
        </Reference>
        <Reference Include="BulletSharpPInvoke">
            <HintPath>..\..\Nu\Nu.Dependencies\BulletSharpPInvoke\netstandard2.1\BulletSharp.dll</HintPath>
        </Reference>
        <Reference Include="OpenGL.Net">
            <HintPath>..\..\Nu\Nu.Dependencies\OpenGL.NET\lib\netcoreapp2.2\OpenGL.Net.dll</HintPath>
        </Reference>
        <Reference Include="TiledSharp">
            <HintPath>..\..\Nu\Nu.Dependencies\TiledSharp\lib\netstandard2.0\TiledSharp.dll</HintPath>
        </Reference>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\Nu\Nu\Nu.fsproj" />
        <ProjectReference Include="..\..\Nu\Nu.Math\Nu.Math.csproj" />
        <ProjectReference Include="..\..\Nu\Nu.Spine\Nu.Spine.csproj" />
    </ItemGroup>

    <Target Name="ValidateIosNativeDependencies" BeforeTargets="_ExpandNativeReferences" Condition="'$(TargetPlatformIdentifier)'=='ios'">
        <Error Text="Missing iOS SDL3 native framework package. Restore NuGet packages or update SandBox2dPpySdlVersion." Condition="!Exists('$(NuGetPackageRoot)ppy.sdl3-cs/$(SandBox2dPpySdlVersion)/runtimes/ios/native/SDL3.xcframework')" />
        <Error Text="Missing iOS SDL3_image native framework package. Restore NuGet packages or update SandBox2dPpySdlVersion." Condition="!Exists('$(NuGetPackageRoot)ppy.sdl3_image-cs/$(SandBox2dPpySdlVersion)/runtimes/ios/native/SDL3_image.xcframework')" />
        <Error Text="Missing iOS SDL3_ttf native framework package. Restore NuGet packages or update SandBox2dPpySdlVersion." Condition="!Exists('$(NuGetPackageRoot)ppy.sdl3_ttf-cs/$(SandBox2dPpySdlVersion)/runtimes/ios/native/SDL3_ttf.xcframework')" />
        <Error Text="Missing iOS SDL3_mixer native framework package. Restore NuGet packages or update SandBox2dPpySdlVersion." Condition="!Exists('$(NuGetPackageRoot)ppy.sdl3_mixer-cs/$(SandBox2dPpySdlVersion)/runtimes/ios/native/SDL3_mixer.xcframework')" />
        <Error Text="Missing iOS Assimp xcframework. Run Nu/Nu.External/build-ios-native-dependencies.sh from the repository root." Condition="!Exists('..\..\Nu\Nu.Dependencies\AssimpNet\iOS\assimp.xcframework')" />
        <Error Text="Missing iOS Bullet xcframework. Run Nu/Nu.External/build-ios-native-dependencies.sh from the repository root." Condition="!Exists('..\..\Nu\Nu.Dependencies\BulletSharpPInvoke\iOS\bulletc.xcframework')" />
        <Error Text="Missing iOS Jolt xcframework. Run Nu/Nu.External/build-ios-native-dependencies.sh from the repository root." Condition="!Exists('..\..\Nu\Nu.Dependencies\JoltPhysics\iOS\joltc.xcframework')" />
        <Error Text="Missing iOS cimgui xcframework. Run Nu/Nu.External/build-ios-native-dependencies.sh from the repository root." Condition="!Exists('..\..\Nu\Nu.Dependencies\ImGui\iOS\cimgui.xcframework')" />
        <Error Text="Missing iOS VMA xcframework. Run Nu/Nu.External/build-ios-native-dependencies.sh from the repository root." Condition="!Exists('..\..\Nu\Nu.Dependencies\Vortice.VulkanMemoryAllocator\iOS\vma.xcframework')" />
    </Target>

    <!-- AssimpNet classifies iOS as Linux; patch the iOS-only copy to use its macOS dylib loader. -->
    <Target Name="PatchSandBox2dIosAssimpNet" BeforeTargets="ResolveReferences;ResolveAssemblyReferences" Condition="'$(TargetPlatformIdentifier)'=='ios'" Inputs="$(SandBox2dAssimpNetOriginalDir)/AssimpNet.dll" Outputs="$(SandBox2dAssimpNetReferencePath)">
        <MakeDir Directories="$(SandBox2dAssimpNetPatchedDir)" />
        <Copy SourceFiles="$(SandBox2dAssimpNetOriginalDir)/AssimpNet.dll;$(SandBox2dAssimpNetOriginalDir)/AssimpNet.pdb;$(SandBox2dAssimpNetOriginalDir)/AssimpNet.xml" DestinationFolder="$(SandBox2dAssimpNetPatchedDir)" SkipUnchangedFiles="true" />
        <Exec Command="perl -0777 -pi -e '$u=qr/\x18\x80(.{4})\x2a\x17\x80\1\x2a\x18\x80\1\x2a\x16\x80\1\x2a/s; $p=qr/\x18\x80(.{4})\x2a\x18\x80\1\x2a\x18\x80\1\x2a\x16\x80\1\x2a/s; s/$u/\x18\x80$1\x2a\x18\x80$1\x2a\x18\x80$1\x2a\x16\x80$1\x2a/s or /$p/ or die &quot;AssimpNet iOS platform patch pattern not found\n&quot;' &quot;$(SandBox2dAssimpNetReferencePath)&quot;" />
    </Target>

    <Target Name="CopyMacOSVulkanSdk" BeforeTargets="_ExpandNativeReferences;AssignTargetPaths" DependsOnTargets="ResolveMacOSVulkanSdk" Condition="'$(BuildingMacOS)'=='true' Or '$(TargetPlatformIdentifier)'=='ios'">
        <Error Text="Please install the macOS Vulkan SDK. If installed to a non-default location, override the MacOSVulkanSdk property in this file." Condition="!$([System.IO.Directory]::Exists($(MacOSVulkanSdk)))" />
        <Error Text="No iOS MoltenVK xcframework was found at '$(MacOSVulkanSdk)/iOS/lib/MoltenVK.xcframework'." Condition="'$(TargetPlatformIdentifier)'=='ios' And !$([System.IO.Directory]::Exists($(MacOSVulkanSdk)/iOS/lib/MoltenVK.xcframework))" />
        <ItemGroup>
            <MacOSVulkanSdkDylib Include="$(MacOSVulkanSdk)/macOS/lib/*.dylib" />
            <MacOSVulkanSdkIcdJson Include="$(MacOSVulkanSdk)/macOS/share/**/*_icd.json" />
            <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="$(MacOSVulkanSdk)/iOS/lib/libshaderc_combined.a" Kind="Static" />
            <NativeReference Condition="'$(TargetPlatformIdentifier)'=='ios'" Include="$(MacOSVulkanSdk)/iOS/lib/MoltenVK.xcframework" Kind="Framework" />
        </ItemGroup>
        <Error Condition="'$(TargetPlatformIdentifier)'!='ios' And '@(MacOSVulkanSdkDylib)'==''" Text="No macOS Vulkan SDK dylibs were found at '$(MacOSVulkanSdk)/macOS/lib/*.dylib'. Ensure MacOSVulkanSdk points to a valid Vulkan SDK installation." />
        <Exec Condition="'$(TargetPlatformIdentifier)'!='ios'"
              Command="mkdir -p &quot;$(OutDir)%(MacOSVulkanSdkDylib.RecursiveDir)&quot; &amp;&amp; ln -sfn &quot;%(MacOSVulkanSdkDylib.Identity)&quot; &quot;$(OutDir)%(MacOSVulkanSdkDylib.RecursiveDir)%(MacOSVulkanSdkDylib.Filename)%(MacOSVulkanSdkDylib.Extension)&quot;" />
        <Copy Condition="'$(TargetPlatformIdentifier)'!='ios'" SourceFiles="@(MacOSVulkanSdkIcdJson)" DestinationFiles="@(MacOSVulkanSdkIcdJson->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
        <ItemGroup>
            <OutIcdJsonFile Include="$(OutDir)/vulkan/icd.d/*_icd.json" />
        </ItemGroup>
        <WriteLinesToFile Condition="'$(TargetPlatformIdentifier)'!='ios'" File="%(OutIcdJsonFile.Identity)" Lines="$([System.IO.File]::ReadAllText('%(OutIcdJsonFile.Identity)').Replace('../../../lib/','../../'))" Overwrite="true" />
    </Target>

</Project>
