<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<TargetFramework>net10.0</TargetFramework>
		<ProjectGuid>{11386F8B-C0AE-4F9A-B5FD-3112A704DC14}</ProjectGuid>
		<PlatformTarget>AnyCPU</PlatformTarget>
		<ServerGarbageCollection>True</ServerGarbageCollection>
		<TieredPGO>True</TieredPGO>
		<DisableFastUpToDateCheck>True</DisableFastUpToDateCheck>
        <SatelliteResourceLanguages>en</SatelliteResourceLanguages>

		<BlockCompression>BcCompression</BlockCompression>
		<BlockCompression Condition="
	        '$(TargetPlatformIdentifier)' == '' And ('$(RuntimeIdentifier)'=='' And $([System.OperatingSystem]::IsMacOS()) Or $(RuntimeIdentifier.StartsWith('osx'))) Or
			'$(TargetPlatformIdentifier)'=='ios' Or '$(TargetPlatformIdentifier)'=='android'">AstcCompression</BlockCompression>
        <PostBuildEvent>dotnet "$(MSBuildProjectDirectory)/../../Nu/Nu.Pipe/bin/$(Configuration)/$(TargetFramework)/Nu.Pipe.dll" "$(MSBuildProjectDirectory)/" "$(MSBuildProjectDirectory)/bin/$(Configuration)/$(TargetFramework)/" "$(MSBuildProjectDirectory)/refinement/" "$(BlockCompression)" "False"</PostBuildEvent>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Debug|AnyCpu'">
		<WarnOn>FS1182</WarnOn>
		<NoWarn>FS0009;FS1178;FS3391;FS3536;FS3560</NoWarn>
		<Tailcalls>False</Tailcalls>
		<WarningLevel>5</WarningLevel>
		<DefineConstants>TRACE</DefineConstants>
		<WarningsAsErrors>FS0026;FS0049;FS3239;$(WarningsAsErrors)</WarningsAsErrors>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)|$(Platform)'=='Release|AnyCpu'">
		<WarnOn>FS1182</WarnOn>
		<NoWarn>FS0009;FS1178;FS3391;FS3536;FS3560</NoWarn>
		<Tailcalls>False</Tailcalls>
		<WarningLevel>5</WarningLevel>
		<DefineConstants>TRACE</DefineConstants>
		<WarningsAsErrors>FS0026;FS0049;FS3239;$(WarningsAsErrors)</WarningsAsErrors>
	</PropertyGroup>

    <Target Name="BuildNuPipe" BeforeTargets="BeforeBuild">
        <MSBuild Projects="$(MSBuildProjectDirectory)/../../Nu/Nu.Pipe/Nu.Pipe.fsproj" RemoveProperties="TargetFramework;RuntimeIdentifier;SelfContained" Targets="Restore;Build" />
    </Target>

	<Target Name="AfterCleanNuPipe" AfterTargets="Clean">
		<RemoveDir Directories="refinement" />
		<RemoveDir Directories="$(OutDir)/Assets" />
	</Target>

	<ItemGroup>
        <None Include="Assets\*" />
        <None Include="Assets\*\*" />
		<Compile Include="GaiaConstants.fs" />
		<Compile Include="GaiaPrelude.fs" />
		<Compile Include="Gaia.fs" />
		<Compile Include="GaiaPlugin.fs" />
		<Compile Include="Program.fs" />
		<Content Include="AssetGraph.nuag">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<Content Include="Overlayer.nuol">
			<CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
		</Content>
		<None Include="App.config" />
	</ItemGroup>

	<ItemGroup>
		<Reference Include="AssimpNet">
			<HintPath>..\..\Nu\Nu.Dependencies\AssimpNet\netstandard2.1\AssimpNet.dll</HintPath>
		</Reference>
		<Reference Include="BulletSharpPInvoke">
			<HintPath>..\..\Nu\Nu.Dependencies\BulletSharpPInvoke\netstandard2.1\BulletSharp.dll</HintPath>
		</Reference>
		<Reference Include="OpenGL.Net">
			<HintPath>..\..\Nu\Nu.Dependencies\OpenGL.NET\lib\netcoreapp2.2\OpenGL.Net.dll</HintPath>
		</Reference>
		<Reference Include="TiledSharp">
			<HintPath>..\..\Nu\Nu.Dependencies\TiledSharp\lib\netstandard2.0\TiledSharp.dll</HintPath>
		</Reference>
		<PackageReference Include="FSharp.Compiler.Service" Version="43.10.103" />
	</ItemGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Nu\Nu\Nu.fsproj" />
		<ProjectReference Include="..\..\Nu\Nu.Math\Nu.Math.csproj" />
		<ProjectReference Include="..\..\Nu\Nu.Spine\Nu.Spine.csproj" />
	</ItemGroup>

	<Target Name="BuildNuPipe" BeforeTargets="BeforeBuild">
	    <MSBuild Projects="../../Nu/Nu.Pipe/Nu.Pipe.fsproj"
	        RemoveProperties="TargetFramework;RuntimeIdentifier;SelfContained"
	        Targets="Restore;Build" />
    </Target>
	<Target Name="NuPipe" BeforeTargets="AssignTargetPaths" DependsOnTargets="BuildNuPipe">
		<!-- non-iOS: call NuPipe via BeforeTargets="AssignTargetPaths" -->
	    <MSBuild Projects="../../Nu/Nu.Pipe/Nu.Pipe.fsproj"
	        RemoveProperties="TargetFramework;RuntimeIdentifier;SelfContained"
	        Properties="NoBuild=true;RunArguments=&quot;$(MSBuildProjectDirectory)/&quot; &quot;$(MSBuildProjectDirectory)/refinement-out/&quot; &quot;$(MSBuildProjectDirectory)/refinement/&quot; &quot;False&quot;"
	        Targets="Run" />
        <ItemGroup>
			<MauiAsset Include="refinement-out/**/*.*" />
		</ItemGroup>
        <Copy Condition="'$(UseMaui)' != 'true'"
            SourceFiles="@(MauiAsset)"
            DestinationFolder="$(MSBuildProjectDirectory)/bin/$(Configuration)/$(TargetFramework)/%(RecursiveDir)" />
    </Target>

  <PropertyGroup>
    <!-- Override the macOS Vulkan SDK path here -->
    <MacOSVulkanSdk></MacOSVulkanSdk>
  </PropertyGroup>
  <Target Name="CopyMacOSVulkanSdk" BeforeTargets="AssignTargetPaths" Condition="
	'$(TargetPlatformIdentifier)' == '' And ('$(RuntimeIdentifier)'=='' And $([System.OperatingSystem]::IsMacOS()) Or $(RuntimeIdentifier.StartsWith('osx'))) Or
	'$(TargetPlatformIdentifier)'=='ios'">
	<Exec Condition="'$(MacOSVulkanSdk)' == '' And $([System.OperatingSystem]::IsMacOS())" Command='
		if [ -x ~/.bash_profile ]
		then source ~/.bash_profile
		fi
		if [ "$VULKAN_SDK" == "" ] # Try to read VULKAN_SDK from bash_profile first
		then VULKAN_SDK=`ls -d ~/VulkanSDK/* | grep -E "[^/]+/[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$" | sort -V -r | head -n 1` # By default, the Vulkan SDK for macOS is installed in ~/VulkanSDK with versioned subdirectories
		fi
		echo "$VULKAN_SDK"
	' ConsoleToMsBuild="true">
      <Output TaskParameter="ConsoleOutput" PropertyName="MacOSVulkanSdk" />
    </Exec>
    <Error Text="Please install the macOS Vulkan SDK. If installed to a non-default location, override the MacOSVulkanSdk property in this file." Condition="!$([System.IO.Directory]::Exists($(MacOSVulkanSdk)))" />
    <ItemGroup>
      <MacOSVulkanSdkFile Include="$(MacOSVulkanSdk)/macOS/lib/*.dylib" />
      <!-- The magic of icd.json copying and path fixing enables KosmicKrisp :) -->
      <MacOSVulkanSdkFile Include="$(MacOSVulkanSdk)/macOS/share/**/*_icd.json" />
      <iOSVulkanSdkFile Include="$(MacOSVulkanSdk)/iOS/lib/**/*" />
    </ItemGroup>
    <Copy Condition="'$(TargetPlatformIdentifier)'!='ios'" SourceFiles="@(MacOSVulkanSdkFile)" DestinationFiles="@(MacOSVulkanSdkFile->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
    <Copy Condition="'$(TargetPlatformIdentifier)'=='ios'" SourceFiles="@(iOSVulkanSdkFile)" DestinationFiles="@(iOSVulkanSdkFile->'$(OutDir)%(RecursiveDir)%(Filename)%(Extension)')" SkipUnchangedFiles="true" />
    <ItemGroup>
      <OutIcdJsonFile Include="$(OutDir)/vulkan/icd.d/*_icd.json" />
    </ItemGroup>
    <WriteLinesToFile Condition="'$(TargetPlatformIdentifier)'!='ios'"
      File="%(OutIcdJsonFile.Identity)"
      Lines="$([System.IO.File]::ReadAllText('%(OutIcdJsonFile.Identity)').Replace('../../../lib/','../../'))"
      Overwrite="true" />
  </Target>

</Project>