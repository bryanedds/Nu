<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
    </PropertyGroup>

    <Import Project="../../Nu/Nu.Common.targets" />

    <Target Name="BuildGaiaProjects" AfterTargets="BuildNuPipe" BeforeTargets="BeforeBuild">
        <ItemGroup>
            <GaiaProject Include="../../Projects/*/*.fsproj" />
        </ItemGroup>
        <!-- Supply TargetFrameworks to avoid building mobile target frameworks for desktop Gaia.
             Using TargetFrameworks (plural) overrides projects with <TargetFrameworks> (e.g. Sand Box 2d),
             limiting them to only the desktop framework. Projects with <TargetFramework> (singular)
             will also respect this override. -->
        <MSBuild Projects="@(GaiaProject)" Targets="Build" BuildInParallel="true" Properties="TargetFrameworks=$(TargetFramework)" />
    </Target>

    <ItemGroup>
        <None Include="Assets\*" />
        <None Include="Assets\*\*" />
        <Compile Include="GaiaConstants.fs" />
        <Compile Include="GaiaPrelude.fs" />
        <Compile Include="Gaia.fs" />
        <Compile Include="GaiaPlugin.fs" />
        <Compile Include="Program.fs" />
        <None Include="AssetGraph.nuag" />
        <None Include="Overlayer.nuol" />
        <None Include="App.config" />

        <PackageReference Include="FSharp.Compiler.Service" Version="43.12.204" />
    </ItemGroup>

</Project>
