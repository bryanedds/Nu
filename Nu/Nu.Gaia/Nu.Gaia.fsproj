<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <!-- Gaia is a desktop-only tool (editor/IDE for Nu games) -->
        <TargetFramework>net10.0</TargetFramework>
        <OutputType>Exe</OutputType>
    </PropertyGroup>

    <Import Project="../../Nu/Nu.Common.targets" />

    <!-- Override BuildNuPipe: also build all game projects in addition to Nu.Pipe -->
    <Target Name="BuildNuPipe" BeforeTargets="BeforeBuild">
        <MSBuild Projects="../../Nu/Nu.Pipe/Nu.Pipe.fsproj"
                 RemoveProperties="TargetFramework;RuntimeIdentifier;SelfContained"
                 Targets="Restore;Build" />
        <ItemGroup>
            <GaiaProject Include="../../Projects/*/*.fsproj" />
        </ItemGroup>
        <MSBuild Projects="@(GaiaProject)" Targets="Restore;Build" BuildInParallel="true" />
    </Target>

    <!-- ============================================================
         Project Source Files
         ============================================================ -->

    <ItemGroup>
        <None Include="Assets\*" />
        <None Include="Assets\*\*" />
        <Compile Include="GaiaConstants.fs" />
        <Compile Include="GaiaPrelude.fs" />
        <Compile Include="Gaia.fs" />
        <Compile Include="GaiaPlugin.fs" />
        <Compile Include="Program.fs" />
        <None Include="AssetGraph.nuag" />
        <None Include="Overlayer.nuol" />
        <None Include="App.config" />
    </ItemGroup>

    <!-- ============================================================
         Gaia-specific Dependencies
         ============================================================ -->

    <ItemGroup>
        <PackageReference Include="FSharp.Compiler.Service" Version="43.12.204" />
    </ItemGroup>

</Project>
